# Dependencies
node_modules/
.pnpm-store/

# Build output (shared / server / web all emit dist/)
dist/
out/

# TypeScript incremental build cache
*.tsbuildinfo

# Vite
.vite/
vite.config.*.timestamp-*

# Playwright (browsers, run artifacts, traces)
test-results/
playwright-report/
playwright/.cache/
.last-run.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment / local secrets — never commit real credentials.
# Secrets belong in the OS keychain (keytar), not in files.
.env
.env.*
!.env.example

# Runtime data
*.pid
*.seed
*.pid.lock

# Editor / OS cruft
.DS_Store
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Claude Code local overrides (shared config is committed)
.claude/settings.local.json
